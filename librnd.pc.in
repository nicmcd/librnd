prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include
datarootdir = ${prefix}/share
datadir=${prefix}/share

Name: librnd
Description: An easy to use random number generator for C++ that wraps std::random.
URL: https://github.com/nicmcd/librnd
Version: 0.1.0
Requires: libprim
Libs: -L${libdir} -lrnd 
Cflags: -I${includedir}
